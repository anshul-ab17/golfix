generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  LAPSED
}

enum WinnerStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  password           String
  role               Role               @default(USER)
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  charityId          String?
  charityPercentage  Int                @default(10)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  scores   Score[]
  winners  Winner[]
  charity  Charity? @relation(fields: [charityId], references: [id])
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  date      DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Charity {
  id          String   @id @default(cuid())
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model Draw {
  id        String   @id @default(cuid())
  month     DateTime @unique
  numbers   Int[]
  createdAt DateTime @default(now())

  winners Winner[]
}

model Winner {
  id        String       @id @default(cuid())
  userId    String
  drawId    String
  matchType Int
  status    WinnerStatus @default(PENDING)
  proofUrl  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])
  draw Draw @relation(fields: [drawId], references: [id])
}
